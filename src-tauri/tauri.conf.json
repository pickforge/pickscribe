{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PickScribe",
  "version": "0.1.1",
  "identifier": "com.pickforge.pickscribe",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PickScribe",
        "width": 1020,
        "height": 720,
        "minWidth": 780,
        "minHeight": 560,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pickforge/pickscribe/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5RkREMjlBQTZEM0RFQTEKUldTaDN0T21tdEw5eVlPZTlNNlloQnFtVkp4M1RpYndKYUhYWXE0WWJZS09OVmZqbEJkS3FSazYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
