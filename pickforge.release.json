{
  "schemaVersion": 1,
  "repository": "pickforge/pickscribe",
  "appName": "PickScribe",
  "tauriConfig": "src-tauri/tauri.conf.json",
  "collect": {
    "artifactRoot": "target/release/bundle",
    "outputDir": "release-assets",
    "patterns": [
      "*.AppImage",
      "*.AppImage.sig",
      "*.app.tar.gz",
      "*.app.tar.gz.sig",
      "*.deb",
      "*.deb.sig"
    ]
  },
  "stable": {
    "tagPrefix": "v",
    "latestJsonAsset": "latest.json"
  },
  "updater": {
    "requiredPlatforms": ["linux-x86_64", "darwin-aarch64"]
  }
}
